venv/

__pycache__/
*.pyc
*.pyo
*.pyd

# Telegram state (contains user IDs)
core/telegram/state.json

# Worker outputs (generated at runtime)
worker/outputs/*.txt
worker/outputs/_active_workers.json
worker/outputs/_browser_queue.json
worker/outputs/_worker_registry.json

# Session files (generated at runtime)
sessions/

# Telegram media (downloaded at runtime)
core/telegram/media/

# Runtime state
.restart_pending
.DS_Store
.silicon-upstream/
